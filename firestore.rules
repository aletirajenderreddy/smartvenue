rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signed() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid()));
    }

    function role() {
      return signed() && userDoc().data.role != null ? userDoc().data.role : '';
    }

    function isAdmin() {
      return signed() && role() == 'admin';
    }

    function isGate() {
      return signed() && role() == 'gate_staff';
    }

    function isOps() {
      return isAdmin() || isGate();
    }

    function own(userId) {
      return signed() && uid() == userId;
    }

    function validUserCreate(userId) {
      return own(userId)
        && request.resource.data.keys().hasOnly([
          'name', 'email', 'phone', 'photoURL', 'role', 'fcmToken', 'language',
          'slotId', 'ticketId', 'loyaltyPoints', 'createdAt', 'updatedAt',
          'seatZone', 'zoneId', 'busSubscriptions', 'stamps', 'souvenirUnlocked'
        ])
        && request.resource.data.role == 'attendee';
    }

    function validUserUpdate(userId) {
      return own(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'email', 'phone', 'photoURL', 'fcmToken', 'language',
          'slotId', 'ticketId', 'updatedAt', 'seatZone', 'zoneId',
          'busSubscriptions', 'stamps', 'souvenirUnlocked'
        ]);
    }

    match /users/{userId} {
      allow read: if own(userId) || isAdmin();
      allow create: if validUserCreate(userId) || isAdmin();
      allow update: if validUserUpdate(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if signed();
      allow write: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isOps() || (signed() && resource.data.userId == uid());
      allow create, update: if isOps();
      allow delete: if isAdmin();
    }

    match /slots/{slotId} {
      allow read: if signed();
      allow write: if isAdmin();
    }

    match /zones/{zoneId} {
      allow read: if signed();
      allow write: if isAdmin();
    }

    match /stalls/{stallId} {
      allow read: if signed();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isOps() || (signed() && resource.data.userId == uid());
      allow create: if signed()
        && request.resource.data.userId == uid()
        && request.resource.data.status == 'pending'
        && request.resource.data.total is number
        && request.resource.data.items is list;
      allow update: if isOps();
      allow delete: if isAdmin();
    }

    match /buses/{busId} {
      allow read: if signed();
      allow write: if isAdmin();
    }

    match /sos_alerts/{alertId} {
      allow read: if isOps() || (signed() && resource.data.userId == uid());
      allow create: if signed()
        && request.resource.data.userId == uid()
        && request.resource.data.type in ['SOS', 'Medical Emergency', 'Fire', 'Missing Person'];
      allow update: if isOps();
      allow delete: if isAdmin();
    }

    match /lost_items/{itemId} {
      allow read: if signed();
      allow create: if signed()
        && request.resource.data.reportedBy == uid()
        && request.resource.data.status in ['lost', 'found'];
      allow update: if isAdmin()
        || (signed()
          && resource.data.reportedBy == uid()
          && request.resource.data.reportedBy == uid()
          && request.resource.data.status in ['lost', 'found']);
      allow delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin() || (signed() && resource.data.userId == uid());
      allow create: if signed()
        && request.resource.data.userId == uid()
        && request.resource.data.rating is number
        && request.resource.data.crowdRating is number
        && request.resource.data.foodRating is number;
      allow update, delete: if isAdmin();
    }

    match /scan_logs/{scanId} {
      allow read: if isOps();
      allow write: if isAdmin();
    }

    match /gamification_events/{eventId} {
      allow read: if isAdmin() || (signed() && resource.data.uid == uid());
      allow write: if isAdmin();
    }

    match /processed_payments/{paymentId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
